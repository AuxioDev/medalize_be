# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost

# Database
DB_NAME=medalize_db
DB_USER=medalizer_user
DB_PASSWORD=strong-password-here
DB_HOST=postgres
DB_PORT=5432

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-here-minimum-50-characters-long

# Email (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@medalize.com

# Frontend (used in password reset links)
FRONTEND_URL=https://yourdomain.com

# Cloudinary CDN (media: doctor diplomas, avatars).
# Leave blank to store uploads on the local filesystem (development default).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
