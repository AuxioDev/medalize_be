# Django
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,localhost

# Database
DB_NAME=medalize_db
DB_USER=medalizer_user
DB_PASSWORD=strong-password-here
DB_HOST=postgres
DB_PORT=5432

# JWT — MUST be different from SECRET_KEY above; both must be ≥50 chars.
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
JWT_SECRET_KEY=your-jwt-secret-key-here-minimum-50-characters-long-different-from-secret-key

# Email (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@medalize.com

# Frontend (used in password reset links)
FRONTEND_URL=https://yourdomain.com

# CORS — origins allowed to call the API (web frontends). Mobile apps don't need this.
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Redis (Celery broker + cache)
REDIS_URL=redis://redis:6379/0

# Cloudinary CDN (media: doctor diplomas, avatars).
# Leave blank to store uploads on the local filesystem (development default).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
